{
  "manifest_version": 2,
  "name": "Google Calendar View Optimizer",
  "version": "1.0.0",
  "description": "Hides early morning hours from your calendar view to avoid large empty space",
  "permissions": [
    "https://calendar.google.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://calendar.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png"
  }
}